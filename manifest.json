{
  "manifest_version": 3,
  "name": "MGC Equivalent Code Generator",
  "description": "Generates equivalent CLI and Terraform code from the Magalu Cloud console",
  "version": "1.0.0",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://console.magalu.cloud/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://console.magalu.cloud/*"],
      "js": [
        "src/mappings.js",
        "src/generators.js",
        "src/content.js"
      ],
      "css": ["styles/sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "MGC Equivalent Code"
  }
}
